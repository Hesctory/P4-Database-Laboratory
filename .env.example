# Copie este arquivo para `.env` e preencha com suas credenciais locais.
# O `.env` é ignorado pelo git e NÃO deve ser versionado.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=T1 work
DB_USER=postgres
DB_PASSWORD=sua_senha_do_postgres_aqui

# Segredo para assinar os tokens JWT — troque por uma string aleatória.
JWT_SECRET=troque-por-uma-string-aleatoria
